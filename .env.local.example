# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI (via Vercel AI SDK) — optional, only for description cleanup fallback
OPENAI_API_KEY=your_openai_api_key

# Anthropic (Claude) — optional. Powers smart freeform chat parsing.
# Without it, the chat falls back to the local regex parser (free, no AI).
# Get a key at https://console.anthropic.com → uses claude-haiku-4-5.
ANTHROPIC_API_KEY=your_anthropic_api_key
